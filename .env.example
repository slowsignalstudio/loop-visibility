# Anthropic — create a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — copy to .env.local and fill in from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key used by the trace writer (never expose to the client).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
